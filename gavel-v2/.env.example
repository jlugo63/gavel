# Gavel Governance Gateway - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Environment: development | production
GAVEL_ENV=development

# Admin mode: enables admin endpoints (true/false)
GAVEL_ADMIN_MODE=false

# Comma-separated machine IDs allowed to access admin functions
GAVEL_ADMIN_MACHINES=

# Log level: DEBUG | INFO | WARNING | ERROR
GAVEL_LOG_LEVEL=INFO

# Gateway port (mapped in docker-compose.yml)
GAVEL_PORT=8100

# Anthropic API key (required for pocket/LLM features)
# ANTHROPIC_API_KEY=sk-ant-...
